{
  "name": "ledgeraxis-backend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "migrate": "node ./scripts/migrate.js up",
    "migrate:down": "node ./scripts/migrate.js down --count=1",
    "migrate:test": "node ./scripts/migrate-test.js",
    "seed:dev": "node ../scripts/seed-dev.js",
    "seed:demo": "node ../scripts/seed-demo.js",
    "ingest:fixture": "node ../scripts/run-ingestion-fixture.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "test:unit": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand tests/unit",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand tests/integration",
    "test:db": "node ./scripts/migrate-test.js",
    "test:ci": "npm run test:unit && npm run test:integration && npm run test:db",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage --runInBand",
    "lint": "echo 'TODO: configure eslint'"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.8.0",
    "jest": "^29.7.0",
    "node-pg-migrate": "^7.9.1",
    "supertest": "^7.0.0"
  }
}
