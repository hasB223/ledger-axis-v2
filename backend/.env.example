# Backend environment template
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Auth
JWT_SECRET=replace_me
JWT_EXPIRES_IN=1h
BCRYPT_SALT_ROUNDS=12

# PostgreSQL 17
PGHOST=localhost
PGPORT=5432
PGDATABASE=ledgeraxis
PGUSER=ledgeraxis
PGPASSWORD=replace_me
PGSSLMODE=disable

# Tenant-aware defaults (for local ops/testing only)
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000

# Scheduler
INGESTION_CRON=*/15 * * * *

# Swagger
SWAGGER_ENABLED=true
