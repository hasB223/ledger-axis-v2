NODE_ENV=development
PORT=4000
API_PREFIX=/api
API_DOCS_ENABLED=true
CORS_ORIGIN=http://localhost:4200

JWT_SECRET=replace_me
JWT_EXPIRES_IN=1h
BCRYPT_SALT_ROUNDS=12

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10

PGHOST=localhost
PGPORT=5432
PGDATABASE=ledgeraxis
PGUSER=ledgeraxis
PGPASSWORD=replace_me
PGSSLMODE=disable
PGSCHEMA=public

# Optional test database overrides for migrate:test / test:db / CI.
# If omitted, test helpers fall back to PG* values, then to the current OS user.
# PGTESTHOST=localhost
# PGTESTPORT=5432
# PGTESTDATABASE=ledgeraxis_test
# PGTESTUSER=ledgeraxis
# PGTESTPASSWORD=replace_me
# PGTESTSSLMODE=disable
# PGTESTSCHEMA=ledgeraxis_test_suite

INGESTION_CRON=*/30 * * * *
INGESTION_SOURCE_URL=https://example.gov/companies
