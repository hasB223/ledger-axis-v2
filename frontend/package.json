{
  "name": "ledgeraxis-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "LedgerAxis Angular frontend for compliance and due-diligence workflows.",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "start": "node -e \"console.error('Frontend serve is not wired yet. Use npm test for frontend validation.'); process.exit(1)\"",
    "build": "node -e \"console.error('Frontend build is not wired yet. Use npm test for frontend validation.'); process.exit(1)\"",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.js --runInBand",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.js --watch",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.js --coverage --runInBand",
    "lint": "echo 'TODO: configure eslint for Angular strict mode'"
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "chart.js": "^4.4.6",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular/compiler-cli": "^21.0.0",
    "@types/jest": "^30.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "jest-preset-angular": "^16.1.1",
    "jsdom": "^26.0.0",
    "typescript": "^5.6.3"
  }
}
